ENV_SCHEMA_VERSION=2
TELEGRAM_BOT_TOKEN=replace-with-telegram-bot-token
TELEGRAM_API_BASE_URL=http://127.0.0.1:8081
TELEGRAM_API_ID=replace-with-telegram-api-id
TELEGRAM_API_HASH=replace-with-telegram-api-hash
TELEGRAM_BOT_API_BIN=telegram-bot-api
TELEGRAM_BOT_API_HOST=127.0.0.1
TELEGRAM_BOT_API_PORT=8081
TELEGRAM_BOT_API_DIR=./data/telegram-bot-api
ALLOWED_CHAT_ID=replace-with-telegram-group-chat-id

OBS_HOST=127.0.0.1
OBS_PORT=4455
OBS_PASSWORD=
OBS_MEDIA_SOURCE_NAME=tg_queue_player
OBS_FALLBACK_FILE=
FALLBACK_MODE=random_played

DATA_DIR=./data
MEDIA_DIR=./data/media
DATABASE_PATH=./data/queue.db

MAX_VIDEO_SIZE_MB=2000
MAX_VIDEO_DURATION_SECONDS=7200
MAX_QUEUE_LENGTH=50
RETENTION_DAYS=7
RETENTION_MAX_FILES=100
FFPROBE_PATH=ffprobe
LOG_LEVEL=info
